# Frontend Environment Variables

# ============================================================
# REQUIRED FOR PRODUCTION
# ============================================================

# Your Backend Server URL (REQUIRED)
# - For local development: http://localhost:3001
# - For testing on other devices: http://YOUR_COMPUTER_IP:3001
# - For production: https://your-domain.com or http://YOUR_SERVER_IP:3001
#
# ⚠️ IMPORTANT: localhost only works on the SAME computer
# For testing with other people, use your public IP or domain!
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
# NEXT_PUBLIC_SOCKET_URL=https://backend-messenger.blockstar.world/

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# Blockchain Configuration - BlockStar Mainnet
# ===================
# Chain ID in hex format
NEXT_PUBLIC_CHAIN_ID=0x1588

# RPC URL for blockchain connection
NEXT_PUBLIC_RPC_URL=https://mainnet-rpc.blockstar.one

# Chain display name
NEXT_PUBLIC_CHAIN_NAME=BlockStar

# Native currency symbol
NEXT_PUBLIC_CHAIN_SYMBOL=BST

# Block explorer URL
NEXT_PUBLIC_EXPLORER_URL=https://scan.blockstar.one

# ===================
# NFT Contract
# ===================
# BlockStar Domains NFT Contract Address
NEXT_PUBLIC_NFT_CONTRACT=0x1E9248a78352150e8b2E7E728346EDd41A77FDeA

# ===================
# IPFS Configuration
# ===================
# IPFS gateway for retrieving files
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Infura IPFS credentials (optional, for uploads)
NEXT_PUBLIC_INFURA_PROJECT_ID=
NEXT_PUBLIC_INFURA_PROJECT_SECRET=

# ===================
# WebRTC Configuration (Optional)
# ===================
# TURN Server for WebRTC (helps with NAT traversal)
NEXT_PUBLIC_TURN_SERVER_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# STUN servers (default uses Google's free STUN servers)
NEXT_PUBLIC_STUN_SERVER_URL=stun:stun.l.google.com:19302

# ===================
# Push Notifications (Optional)
# ===================
# Web Push VAPID public key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ===================
# Feature Flags (Optional)
# ===================
NEXT_PUBLIC_ENABLE_MESH_NETWORK=false
NEXT_PUBLIC_ENABLE_CROSS_CHAIN=false
NEXT_PUBLIC_ENABLE_ZK_PROOFS=false
