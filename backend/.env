# BlockStar Cypher Backend Environment Variables

# ============================================================
# REQUIRED FOR PRODUCTION
# ============================================================

# Your server's public URL (REQUIRED for file uploads to work on other devices)
# For local development: http://localhost:3001
# For production: https://your-domain.com or http://YOUR_PUBLIC_IP:3001
BACKEND_URL=http://localhost:3001

# Server Port
PORT=3001

# Frontend URL for CORS
# For local: http://localhost:3000
# For production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000

# ============================================================
# BLOCKSTAR DOMAINS RESOLVER (On-Chain)
# ============================================================

# BlockStar Domains Resolver URL (for "Edit Profile" links)
RESOLVER_URL=https://domains.blockstar.site

# BlockStar Mainnet Configuration
BLOCKCHAIN_RPC_URL=https://mainnet-rpc.blockstar.one
BLOCKCHAIN_CHAIN_ID=0x1588
BLOCKCHAIN_CHAIN_NAME=BlockStar
BLOCKCHAIN_SYMBOL=BST
BLOCKCHAIN_EXPLORER=https://scan.blockstar.one

# BlockStar Domains NFT Contract Address
DOMAINS_CONTRACT_ADDRESS=0x1E9248a78352150e8b2E7E728346EDd41A77FDeA

# ============================================================
# DATABASE & CACHE
# ============================================================

# MongoDB Connection URI
# Local: mongodb://localhost:27017
# With auth: mongodb://username:password@localhost:27017/blockstar_cypher?authSource=admin
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/blockstar_cypher
MONGODB_URI=mongodb+srv://blockstardeveloper:LUa0gJTCNkB4YkOt@blockstarlaunchpad.l1tbd.mongodb.net/blockstar-cypher

# Database name
DB_NAME=blockstar_cypher

# Redis URL (for sessions and caching)
REDIS_URL=redis://localhost:6379

# ============================================================
# SECURITY
# ============================================================

# JWT Secret (generate a secure random string for production!)
# Generate: openssl rand -hex 32
JWT_SECRET=6224fa3e18ba8edd451f1d43c012f0899f717d3e1d73f678905ec25d4fa27599

# ============================================================
# PUSH NOTIFICATIONS (Optional)
# ============================================================
# Generate VAPID keys at: https://vapidkeys.com

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ============================================================
# ENVIRONMENT
# ============================================================

NODE_ENV=development

# ============================================================
# IMPORTANT NOTES
# ============================================================
# 
# 1. BACKEND_URL must be set to your public URL for file uploads
#    to work when accessed from other devices/networks
#
# 2. For production, use HTTPS with valid SSL certificates
#
# 3. Generate a secure JWT_SECRET for production
#
# 4. Set NODE_ENV=production for production deployments
#
# 5. For MongoDB Atlas (cloud), use the connection string from your cluster
#

FIREBASE_PROJECT_ID=blockstar-cypher
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@blockstar-cypher.iam.gserviceaccount.com
